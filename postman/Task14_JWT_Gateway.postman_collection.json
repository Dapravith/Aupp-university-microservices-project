{
  "info": {
    "name": "Task 14 — JWT Auth, Roles, API Gateway",
    "_postman_id": "7a6f9c4e-14aa-4aa7-8f67-task14collection",
    "description": "End-to-end tests for Task 14. Set {{gateway}} to your gateway URL (default http://localhost:4000). Run requests top-to-bottom. Logins auto-save their tokens.",
