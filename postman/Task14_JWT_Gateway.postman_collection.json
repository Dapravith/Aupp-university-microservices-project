        "script": { "type": "text/javascript", "exec": [
          "const d = pm.response.json();",
          "pm.test('login ok', () => pm.expect(pm.response.code).to.eql(200));",
          "pm.collectionVariables.set('admin_token', d.token);"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@university.edu\",\n  \"password\": \"Admin@123\"\n}" },
        "url": { "raw": "{{gateway}}/auth/login", "host": ["{{gateway}}"], "path": ["auth", "login"] }
      }
    },
