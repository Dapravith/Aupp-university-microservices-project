  },
  "variable": [
    { "key": "gateway",       "value": "http://localhost:4000" },
    { "key": "admin_token",   "value": "" },
    { "key": "student_token", "value": "" },
    { "key": "teacher_token", "value": "" },
    { "key": "student_id",    "value": "" },
    { "key": "teacher_id",    "value": "" }
  ],
  "item": [
    {
      "name": "0. Gateway health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{gateway}}/health", "host": ["{{gateway}}"], "path": ["health"] }
      }
    },
    {
      "name": "1. Seed users",
      "request": {
        "method": "POST",
        "url": { "raw": "{{gateway}}/auth/seed", "host": ["{{gateway}}"], "path": ["auth", "seed"] }
      }
    },
    {
      "name": "2. Register custom user (optional)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Custom Student\",\n  \"email\": \"custom@uni.edu\",\n  \"password\": \"Password@123\",\n  \"role\": \"student\"\n}" },
        "url": { "raw": "{{gateway}}/auth/register", "host": ["{{gateway}}"], "path": ["auth", "register"] }
      }
    },
    {
