{
  "info": {
    "name": "Task 13 - Docker Volume Persistence Test",
    "description": "Task 13: Web Container + Database Container + Docker Volume + EC2\n\nThis collection tests Docker Volume persistence by:\n1. Storing data via API\n2. Retrieving data\n3. After MongoDB container is destroyed and recreated, old data should still be accessible.\n\nReplace {{BASE_URL}} with your EC2 public IP (e.g., http://54.123.45.67:5004)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5004",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Step 1 - Health Check",
      "item": [
        {
          "name": "1.1 API Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/health",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "health"]
            },
            "description": "Verify that the auth-service API is running and connected to MongoDB."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Service is healthy', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Root Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/",
              "host": ["{{BASE_URL}}"],
              "path": [""]
            },
            "description": "Check root endpoint returns service info."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Step 2 - Store Data (Register & Login)",
      "item": [
        {
          "name": "2.1 Register User (Store Data)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Dapravith Rotha\",\n    \"username\": \"dapravith\",\n    \"email\": \"dapravith@aupp.edu.kh\",\n    \"password\": \"password123\",\n    \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. This data is stored in MongoDB."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User registered successfully', function () {",
                  "    pm.response.to.have.status(201);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Register Admin User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Admin User\",\n    \"username\": \"admin\",\n    \"email\": \"admin@aupp.edu.kh\",\n    \"password\": \"admin123\",\n    \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            },
            "description": "Register an admin user for testing user listing."
          },
          "response": []
        },
        {
          "name": "2.3 Register Teacher User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Teacher User\",\n    \"username\": \"teacher01\",\n    \"email\": \"teacher@aupp.edu.kh\",\n    \"password\": \"teacher123\",\n    \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a teacher user."
          },
          "response": []
        },
        {
          "name": "2.4 Login Student (Get Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"dapravith\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "Login to get JWT token. Token is automatically saved to collection variable."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.collectionVariables.set('TOKEN', json.token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Step 3 - Retrieve Data",
      "item": [
        {
          "name": "3.1 Get Profile (Retrieve Stored Data)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "profile"]
            },
            "description": "Retrieve the user profile. This confirms data is stored in MongoDB."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data.fullName).to.eql('Dapravith Rotha');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Login Admin & Get All Users",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"admin\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as admin to list all users."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('TOKEN', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 List All Users (Verify All Records)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/users",
              "host": ["{{BASE_URL}}"],
              "path": ["users"]
            },
            "description": "List all registered users. Should show 3 users (student, admin, teacher)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('All users retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Step 4-5 - After MongoDB Destroyed (FAIL)",
      "item": [
        {
          "name": "4.1 Try Login After MongoDB Destroyed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"dapravith\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "AFTER destroying MongoDB container:\n  docker compose -f docker-compose-task13.yml stop mongodb\n  docker compose -f docker-compose-task13.yml rm -f mongodb\n\nThis request should FAIL because MongoDB is not running."
          },
          "response": []
        },
        {
          "name": "4.2 Try Get Profile After MongoDB Destroyed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "profile"]
            },
            "description": "This should FAIL - MongoDB container is destroyed, no data access possible."
          },
          "response": []
        },
        {
          "name": "4.3 Health Check (DB Disconnected)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/health",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "health"]
            },
            "description": "Health check should show database is disconnected (readyState != 1)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Step 6-7 - After MongoDB Recreated (SUCCESS)",
      "item": [
        {
          "name": "6.1 Login After MongoDB Recreated",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"dapravith\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "AFTER recreating MongoDB container:\n  docker compose -f docker-compose-task13.yml up -d mongodb\n\nThis should SUCCEED! Docker Volume preserved the data."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login succeeds with old data', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.collectionVariables.set('TOKEN', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6.2 Get Profile (Old Data Persisted!)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "profile"]
            },
            "description": "Old user profile data is accessible because Docker Volume preserved MongoDB data!"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Old data is accessible via volume', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data.fullName).to.eql('Dapravith Rotha');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6.3 Login Admin & List All Users (All Records Preserved)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"admin\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "Admin can still login - all user records preserved by Docker Volume."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login with old credentials works', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('TOKEN', json.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6.4 List All Users (All 3 Users Still Exist)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/users",
              "host": ["{{BASE_URL}}"],
              "path": ["users"]
            },
            "description": "All 3 registered users (student, admin, teacher) still exist after MongoDB container was destroyed and recreated. Docker Volume preserved all data!"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('All users still exist after volume restore', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
