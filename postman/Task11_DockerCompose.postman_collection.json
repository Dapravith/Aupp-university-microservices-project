    {
      "name": "1. Generate JWT Tokens",
      "item": [
        {
          "name": "Generate Student Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' })).replace(/=/g, '');",
                  "const payload = btoa(JSON.stringify({",
                  "    userId: 'student001',",
                  "    username: 'john_student',",
                  "    role: 'student',",
                  "    iat: Math.floor(Date.now() / 1000),",
                  "    exp: Math.floor(Date.now() / 1000) + 86400",
                  "})).replace(/=/g, '');",
                  "",
                  "// Use CryptoJS from Postman sandbox",
                  "const CryptoJS = require('crypto-js');",
                  "const signature = CryptoJS.HmacSHA256(",
                  "    header + '.' + payload,",
                  "    pm.collectionVariables.get('JWT_SECRET')",
                  ").toString(CryptoJS.enc.Base64).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
                  "",
                  "const token = header + '.' + payload + '.' + signature;",
                  "pm.collectionVariables.set('STUDENT_TOKEN', token);",
                  "console.log('Student Token generated');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Student token was generated', function () {",
                  "    const token = pm.collectionVariables.get('STUDENT_TOKEN');",
                  "    pm.expect(token).to.be.a('string');",
                  "    pm.expect(token.split('.')).to.have.lengthOf(3);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{STUDENT_URL}}/health",
              "host": ["{{STUDENT_URL}}"],
              "path": ["health"]
            },
            "description": "This request generates a student JWT token in the pre-request script. The actual GET /health call is just a placeholder."
          }
        },
        {
          "name": "Generate Teacher Token",
          "event": [
